# Pageel CMS v2.0 — Environment Variables
# Copy this file to .env and fill in your values

# Auth — Required
CMS_USER=admin
CMS_PASS_HASH="$2a$12$your-bcrypt-hash-here"
CMS_SECRET=your-random-secret-at-least-16-chars

# Git — Required
GITHUB_TOKEN=ghp_your-fine-grained-token
CMS_REPO=owner/repo-name

# Git service: github | gitea | gogs (default: github)
CMS_SERVICE=github

# Gitea/Gogs only — instance URL (e.g., https://gitea.example.com)
# CMS_INSTANCE_URL=
