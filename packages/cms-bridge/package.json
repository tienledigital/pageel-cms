{
  "name": "@pageel/cms",
  "version": "0.1.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/pageel/pageel-cms",
    "directory": "packages/cms-bridge"
  },
  "type": "module",
  "main": "dist/index.js",
